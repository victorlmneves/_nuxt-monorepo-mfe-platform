# Required so Nuxt can find its peer deps (postcss-loader, css-loader, etc.)
# from the root node_modules rather than failing to resolve them.
shamefully-hoist=true

# Prevent the Vue 2 vue-loader@15 (used by Vue 2 remotes) from being hoisted
# over vue-loader@17 which Nuxt needs. Each app's local devDep takes priority
# when shamefully-hoist is true because pnpm resolves local first.
