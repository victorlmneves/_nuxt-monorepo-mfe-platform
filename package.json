{
  "name": "mfe-platform",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.7",
      "webpack": "5.98.0",
      "postcss": "^8.4.0"
    }
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:shell": "pnpm --filter shell dev",
    "dev:checkout": "pnpm --filter mfe-vue2-checkout dev",
    "dev:admin": "pnpm --filter mfe-vue2-admin dev",
    "dev:profile": "pnpm --filter mfe-vue3-profile dev",
    "dev:dashboard": "pnpm --filter mfe-vue3-dashboard dev",
    "build": "turbo run build",
    "build:all": "turbo run build",
    "start": "pnpm --filter shell start",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dev:local": "bash ./scripts/start-local.sh",
    "health:all": "node ./scripts/health-check.js",
    "dev:remote:checkout": "node ./scripts/dev-remote-server.js --dir ./apps/mfe-vue2-checkout/dist  --port 3001",
    "dev:remote:admin": "node ./scripts/dev-remote-server.js --dir ./apps/mfe-vue2-admin/dist     --port 3002",
    "dev:remote:profile": "node ./scripts/dev-remote-server.js --dir ./apps/mfe-vue3-profile/dist   --port 3003",
    "dev:remote:dashboard": "node ./scripts/dev-remote-server.js --dir ./apps/mfe-vue3-dashboard/dist --port 3004",
    "dev:remotes": "pnpm run -w --parallel dev:remote:checkout dev:remote:admin dev:remote:profile dev:remote:dashboard"
  },
  "devDependencies": {
    "@nuxt/webpack-builder": "^4.3.0",
    "turbo": "^2.0.0",
    "webpack": "5.98.0",
    "webpack-cli": "^6.0.1",
    "css-loader": "^7.1.0",
    "style-loader": "^4.0.0",
    "babel-loader": "^9.1.3",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "postcss": "^8.4.0",
    "esbuild-loader": "^4.3.0",
    "webpack-hot-middleware": "^2.26.1",
    "postcss-loader": "^8.1.1",
    "vue-loader": "17",
    "ufo": "*",
    "defu": "*",
    "ofetch": "*"
  },
  "dependencies": {}
}
