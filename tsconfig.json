{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "paths": {
      "@mfe/shared": ["./packages/shared/src/index.ts"],
      "@mfe/shared/*": ["./packages/shared/src/*"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"],
  "exclude": ["node_modules", "**/dist", "**/.output", "**/.nuxt"]
}
